# Указываем компилятор
CXX = g++
# Флаги компиляции (включаем предупреждения и оптимизацию O2)
CXXFLAGS = -Wall -O2

# Имя готовой программы
TARGET = os_lab_prog

# Сборка проекта
all: main.cpp math_functions.cpp
	$(CXX) $(CXXFLAGS) main.cpp math_functions.cpp -o $(TARGET)

# Очистка папки от собранного файла
clean:
	rm -f $(TARGET)